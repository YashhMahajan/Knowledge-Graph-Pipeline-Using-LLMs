# Environment Variables for Knowledge Graph Pipeline
# =================================================

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Model Configuration
MODEL_NAME=llama-3.3-70b-versatile

# Text Processing Parameters
CHUNK_SIZE=150
OVERLAP=30

# LLM Parameters
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=3072

# Processing Configuration
MAX_RETRIES=3
DEBUG=false

# Visualization Settings
FIGURE_SIZE_WIDTH=16
FIGURE_SIZE_HEIGHT=12
NODE_MIN_SIZE=300
NODE_SIZE_FACTOR=200

# Output Configuration
OUTPUT_DIR=./outputs
CACHE_DIR=./cache
